# ------------------------------------------------------------------------------------------------
# ------------------------------------------------------------------------------------------------
# Almacenamiento de nuestro tfstate dentro del backend
# ------------------------------------------------------------------------------------------------
# ------------------------------------------------------------------------------------------------

terraform {
  backend "azurerm" {
    resource_group_name  = "rg-terraform-state"
    storage_account_name = "sttfstatemongo01"
    container_name        = "tfstate"
    key                   = "mongo_dev.tfstate"
  }
}
